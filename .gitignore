# Data Files (large files - don't commit to git)
Technical/data/raw/*.csv
Technical/data/raw/*.zip
Technical/data/raw/*.json
Technical/data/raw/**/*.geojson
Technical/data/raw/**/*.shp
Technical/data/raw/**/*.dbf
Technical/data/raw/**/*.shx
Technical/data/raw/**/*.prj
Technical/data/processed/*.csv
Technical/data/processed/*.json
Technical/data/processed/**/*.geojson
Technical/data/cache/

# Large HTML map files
Output/MAPPING_DELIVERABLES/Interactive_Maps/*.html
Technical/src/frontend/public/MAPPING_DELIVERABLES/Interactive_Maps/*.html

# Large shapefiles from inputs
Inputs/TaylorFiles/**/*.shp

# Large infrastructure data files
Technical/src/data_importers/Projects/Westchester/Technical/data/raw/infrastructure/*.geojson

# But keep README files
!**/README.md
!**/.gitkeep

