# Westchester Sidewalk Analysis - Frontend Environment Variables
# Copy this file to .env.local and update with your values

# API Configuration
# Development: http://localhost:8000
# Production: Update to your production API URL (e.g., https://api.yourdomain.com)
VITE_API_URL=http://localhost:8000

# Application Configuration
VITE_APP_NAME=Westchester Sidewalk Analysis
VITE_APP_VERSION=1.0.0

# Map Configuration (Optional)
# If using custom map tiles or services, add configurations here
# VITE_MAPBOX_TOKEN=your_mapbox_token_here
# VITE_MAP_DEFAULT_CENTER_LAT=41.1220
# VITE_MAP_DEFAULT_CENTER_LNG=-73.7949
# VITE_MAP_DEFAULT_ZOOM=10
