# Westchester County Data Platform - Production Environment Template
# Copy this file to .env.production.local and update with your actual values

# ==============================================================================
# CRITICAL: Replace YOUR-RENDER-URL with your actual Render service URL
# ==============================================================================

# Backend API URL (from Render deployment)
# Example: https://westchester-api-abc123.onrender.com
VITE_API_URL=https://YOUR-RENDER-URL.onrender.com

# Application Configuration
VITE_APP_NAME=Westchester County Data Platform
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production

# Map Configuration (Optional - defaults already set)
VITE_MAP_DEFAULT_CENTER_LAT=41.1220
VITE_MAP_DEFAULT_CENTER_LNG=-73.7949
VITE_MAP_DEFAULT_ZOOM=10

# ==============================================================================
# DEPLOYMENT INSTRUCTIONS
# ==============================================================================
#
# 1. Copy this file:
#    cp .env.production.local.template .env.production.local
#
# 2. Edit .env.production.local and replace YOUR-RENDER-URL with actual URL
#    Get URL from: https://dashboard.render.com (your service URL)
#
# 3. Build production version:
#    npm run build
#
# 4. Deploy dist/ folder to Netlify
#
# ==============================================================================
