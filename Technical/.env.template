# Westchester County Data Platform - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ===========================================
# CENSUS API CONFIGURATION
# ===========================================
# Get your API key from: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# ===========================================
# NY STATE OPEN DATA CONFIGURATION
# ===========================================
# Get your app token from: https://data.ny.gov/
NY_STATE_APP_TOKEN=your_ny_state_app_token_here

# ===========================================
# FEDERAL RESERVE ECONOMIC DATA (FRED)
# ===========================================
# Get your API key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ===========================================
# NYC OPEN DATA CONFIGURATION
# ===========================================
# Get your app token from: https://opendata.cityofnewyork.us/
NYC_OPEN_DATA_APP_TOKEN=your_nyc_open_data_app_token_here

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL database connection
DATABASE_URL=postgresql://username:password@localhost:5432/westchester_data
DB_HOST=localhost
DB_PORT=5432
DB_NAME=westchester_data
DB_USER=username
DB_PASSWORD=password

# ===========================================
# REDIS CACHE CONFIGURATION
# ===========================================
# Redis for caching API responses
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
LOG_FILE=logs/westchester_data_platform.log

# ===========================================
# DATA COLLECTION CONFIGURATION
# ===========================================
# Rate limiting settings
API_REQUEST_DELAY=1.0
MAX_RETRIES=3
RETRY_DELAY=5

# Data storage paths
DATA_ROOT_PATH=../data
RAW_DATA_PATH=../data/raw
PROCESSED_DATA_PATH=../data/processed
CACHE_PATH=../cache

# Collection schedules (in hours)
CENSUS_UPDATE_INTERVAL=24
INFRASTRUCTURE_UPDATE_INTERVAL=168  # 1 week
MUNICIPAL_SERVICES_UPDATE_INTERVAL=168  # 1 week
NY_STATE_UPDATE_INTERVAL=24
WEB_SCRAPE_UPDATE_INTERVAL=72  # 3 days

# ===========================================
# MONITORING AND ALERTS
# ===========================================
# Prometheus metrics
METRICS_PORT=8000
METRICS_ENDPOINT=/metrics

# Email alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_RECIPIENTS=admin@westchester.gov

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# Development mode
DEBUG=False
TESTING=False

# API settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ===========================================
# SECURITY SETTINGS
# ===========================================
# JWT secret for API authentication
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# CORS settings
ALLOWED_ORIGINS=http://localhost:3000,https://westchester.gov